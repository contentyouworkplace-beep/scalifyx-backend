# ScalifyX Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/scalifyx

# Claude AI (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this

# Firebase (for OTP auth verification)
FIREBASE_PROJECT_ID=your_firebase_project_id

# Cloudflare (for website deployment)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# S3 / R2 Storage (for images)
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_BUCKET=scalifyx-assets
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
